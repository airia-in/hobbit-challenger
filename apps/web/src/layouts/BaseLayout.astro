---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { BRAND_DEFAULT_DESCRIPTION, BRAND_DEFAULT_TITLE } from '../lib/brand';
import { themeInitScript } from '../lib/theme';
import { NativeDeepLinkBootstrap } from '../components/NativeDeepLinkBootstrap';
import { ThemeBootstrap } from '../components/ThemeBootstrap';

export interface Props {
  title?: string;
  description?: string;
}

const { title = BRAND_DEFAULT_TITLE, description = BRAND_DEFAULT_DESCRIPTION } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />
    <!-- data-astro-rerun re-applies the theme on each view transition so the
         resolved theme never flashes when navigating between pages. -->
    <script is:inline set:html={themeInitScript} data-astro-rerun />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-[var(--bg-base)] text-[var(--text-primary)] antialiased"
    style="font-family: var(--font-body);"
  >
    <ThemeBootstrap client:load />
    <NativeDeepLinkBootstrap client:load />
    <slot />
  </body>
</html>
