# Frontend (build-time for Astro; docker-compose passes this to web-host build args)
# Local dev:
PUBLIC_API_URL=http://localhost:3001
# Production docker-compose (defaults derive from API_DOMAIN):
# WEB_DOMAIN=hobbit.drcode.ai
# API_DOMAIN=hobbit-api.drcode.ai
# PUBLIC_API_URL=https://hobbit-api.drcode.ai

# Android App Links — injected at web-host image build (scripts/generate-assetlinks.mjs).
# Must match the signing key of the APK that ships (debug today via release.yml assembleDebug;
# release keystore when #180 lands). Obtain SHA-256 with:
#   keytool -list -v -keystore <keystore> -alias <alias>
# Copy the "SHA256:" line (colon-separated hex). Multiple keys: comma-separate.
# ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...
# Debug keystore (default Android SDK):
#   keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android

# Public hostnames for nginx (docker-compose production)
# WEB_DOMAIN=hobbit.drcode.ai
# API_DOMAIN=hobbit-api.drcode.ai

# web-host runtime (docker-compose sets PORT=4321 on the web-host service)
WEB_PORT=4321
HOST=0.0.0.0
PRIMARY_FRONTEND=web

# api runtime (NestJS dev + docker api service)
PORT=3001
# Public web hostname for dashboard links in WhatsApp reminders and AI prompts
# WEB_DOMAIN=hobbit.drcode.ai
# API-only: public web origin for group invite links (/join?token=...).
# Precedence: request Origin → FRONTEND_URL → first CORS_ORIGIN → http://localhost:4321.
# Set when invite links must match a host other than CORS_ORIGIN[0] (LAN IP, emulator, custom port).
# FRONTEND_URL=http://localhost:4321
# FRONTEND_URL=http://192.168.1.10:4321
# Local dev:
CORS_ORIGIN=http://localhost:4321,http://127.0.0.1:4321
# Production docker-compose (defaults derive from WEB_DOMAIN):
# CORS_ORIGIN=https://hobbit.drcode.ai
# FRONTEND_URL=https://hobbit.drcode.ai
# SQLite path is relative to packages/db/prisma/schema.prisma
DATABASE_URL=file:../../../data/dev.db
# Production libSQL/sqld (Turso or self-hosted). Any non-file: URL uses the
# libSQL driver adapter and migrations are applied over the libSQL client at
# startup (Prisma's migrate deploy only supports file: URLs).
#   - JWT auth:   DATABASE_URL=libsql://your-db.turso.io + DATABASE_AUTH_TOKEN=<jwt>
#   - Basic auth: DATABASE_URL=http://user:pass@libsql-host:8080 (creds are moved
#                 out of the URL into an Authorization: Basic header automatically)
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=
JWT_SECRET=dev-secret-change-in-production
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=10485760
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
GUIDANCE_RATE_LIMIT_MAX=20
GUIDANCE_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_WINDOW_MS=60000

# OpenAI (api only — never PUBLIC_*)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_VISION_MODEL=gpt-4o-mini

# WhatsApp / Evolution API (api only)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
# Inbound webhook: POST https://<API_DOMAIN>/api/webhooks/evolution
# Configure Evolution MESSAGES_UPSERT with Authorization: Bearer <secret>
EVOLUTION_WEBHOOK_SECRET=
# Local dev only — never enable in staging/production
# EVOLUTION_WEBHOOK_ALLOW_UNAUTHENTICATED=true
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
# Inbound dedupe row retention (days); cron purges older rows daily
INBOUND_DEDUPE_RETENTION_DAYS=30

# Product analytics (#148). Default ON when unset; set false in test/CI.
PRODUCT_ANALYTICS_ENABLED=true
